name: CI

on:
  push:
    branches: [main, develop]
    paths:
      - "./src/**"
      - "./tests/**"
      - "./devtools/**"
      - "./pyproject.toml"
      - "./uv.lock"
      - "./Makefile"
  pull_request:
    branches: [main, develop]
    paths:
      - "./src/**"
      - "./tests/**"
      - "./devtools/**"
      - "./pyproject.toml"
      - "./uv.lock"
      - "./Makefile"

permissions:
  contents: read

jobs:
  quality:
    name: Code Quality & Tests
    runs-on: ubuntu-latest
    strategy:
      matrix:
        python-version: ["{{ python_ci_version }}"]

    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          # Important for versioning plugins:
          fetch-depth: 0

      - name: Install uv
        uses: astral-sh/setup-uv@v7
        with:
          # Update this as needed:
          version: "0.9.5"
          enable-cache: true
          python-version: {% raw %}${{ matrix.python-version }}{% endraw %}

      - name: Set up Python (using uv)
        run: uv python install

      - name: Install all dependencies
        run: make install

      - name: Run linting
        run: make lint

      - name: Run tests with coverage
        run: make test
